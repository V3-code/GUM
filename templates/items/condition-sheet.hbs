<form class="{{cssClass}} gum-item-sheet condition-sheet effect-sheet" autocomplete="off">
    {{!-- CABEÇALHO ALINHADO AO PADRÃO DOS ITENS --}}
    <header class="sheet-header">
        <img class="profile-img" src="{{item.img}}" data-edit="img" title="{{item.name}}"/>
        <div class="header-info">
            <div class="header-main-line">
                <textarea name="name" rows="1" placeholder="Nome da Condição">{{item.name}}</textarea>
            </div>
            <div class="header-subline">
                <span class="item-type-tag">Condição</span>
            </div>
                <span class="header-divider" aria-hidden="true"></span>
            </div>
    </header>

    <section class="sheet-content">

        {{!-- NAVEGAÇÃO DAS ABAS --}}
        <nav class="sheet-tabs tabs" data-group="primary">
            <a class="item" data-tab="description">Descrição</a>
            <a class="item" data-tab="gatilho">Gatilho</a>
            <a class="item" data-tab="effects">Efeitos</a>
        </nav>

        <section class="sheet-body-content">

            {{!-- ABA: DESCRIÇÃO (MODELO PADRÃO) --}}
            <div class="tab" data-group="primary" data-tab="description">
                <div class="description-tab">
                    <div class="description-grid">
                        <div class="form-section description-section itemdesc-block">
                            <details class="itemdesc-panel" open>
                                <summary class="itemdesc-block-header">
                                    <h4 class="itemdesc-block-title">Descrição Resumida (Chat)</h4>
                                    {{#if editable}}
                                    <span class="itemdesc-header-actions">
                                        <button type="button" class="toggle-editor itemdesc-edit-button" data-field="system.chat_description">
                                            <i class="fas fa-pen"></i>
                                        </button>
                                    </span>
                                    {{/if}}
                                </summary>
                                <div class="itemdesc-content">
                                    <div class="description-view itemdesc-inner">{{{enrichedChatDescription}}}</div>

                                    <div class="description-editor itemdesc-inner" style="display:none;">
                                        {{editor system.chat_description target="system.chat_description" engine="prosemirror" owner=owner editable=editable}}
                                        <div class="description-actions">
                                            <button type="button" class="save-description" data-field="system.chat_description"><i class="fas fa-save"></i> Salvar</button>
                                            <button type="button" class="expand-description" data-expanded="false"><i class="fas fa-expand"></i> Expandir</button>
                                            <button type="button" class="cancel-description"><i class="fas fa-times"></i> Cancelar</button>
                                        </div>
                                    </div>
                                </div>
                            </details>
                        </div>

                        <div class="form-section description-section itemdesc-block">
                            <details class="itemdesc-panel" open>
                                <summary class="itemdesc-block-header">
                                    <h4 class="itemdesc-block-title">Descrição Completa</h4>
                                    {{#if editable}}
                                    <span class="itemdesc-header-actions">
                                        <button type="button" class="toggle-editor itemdesc-edit-button" data-field="system.description">
                                            <i class="fas fa-pen"></i>
                                        </button>
                                    </span>
                                    {{/if}}
                                </summary>
                                <div class="itemdesc-content">
                                    <div class="description-view itemdesc-inner">{{{enrichedDescription}}}</div>

                                    <div class="description-editor itemdesc-inner" style="display:none;">
                                        {{editor system.description target="system.description" engine="prosemirror" owner=owner editable=editable}}
                                        <div class="description-actions">
                                            <button type="button" class="save-description" data-field="system.description"><i class="fas fa-save"></i> Salvar</button>
                                            <button type="button" class="expand-description" data-expanded="false"><i class="fas fa-expand"></i> Expandir</button>
                                            <button type="button" class="cancel-description"><i class="fas fa-times"></i> Cancelar</button>
                                        </div>
                                    </div>
                                </div>
                            </details>
                        </div>
                    </div>
                </div>
            </div>

            {{!-- ABA: GATILHO --}}
            <div class="tab" data-group="primary" data-tab="gatilho">
                <section class="form-section condition-card">
                    <div class="section-header">
                        <div>
                            <p class="eyebrow">Regra de ativação</p>
                            <h4 class="section-title">Gatilho</h4>
                        </div>
                        <span class="section-tag">JavaScript</span>
                    </div>

                    <div class="effect-row-grid effect-duration-grid is-two-col-rows" style="margin-bottom: 8px;">
                        <div class="effect-field effect-field-row">
                            <label class="effect-label">Modo da condição</label>
                            <select name="system.bindingMode">
                                <option value="conditional" {{#if (eq system.bindingMode "conditional")}}selected{{/if}}>When (expressão)</option>
                                <option value="status-link" {{#if (eq system.bindingMode "status-link")}}selected{{/if}}>Vínculo de Status</option>
                            </select>
                        </div>
                    </div>

                    {{#if (eq system.bindingMode "status-link")}}
                    <div class="effect-row-grid effect-duration-grid is-two-col-rows" style="margin-bottom: 8px;">
                        <div class="effect-field effect-field-row">
                            <label class="effect-label">Status vinculado</label>
                            <select name="system.statusBinding.statusId">
                                <option value="">— Selecionar —</option>
                                {{#each statusEffects as |status|}}
                                <option value="{{status.id}}" {{#if (eq ../system.statusBinding.statusId status.id)}}selected{{/if}}>{{status.label}}</option>
                                {{/each}}
                            </select>
                        </div>
                        <div class="effect-field effect-field-row">
                            <label class="effect-label">Empilhamento</label>
                            <select name="system.statusBinding.stackMode">
                                <option value="refresh" {{#if (eq system.statusBinding.stackMode "refresh")}}selected{{/if}}>Atualizar duração</option>
                                <option value="replace" {{#if (eq system.statusBinding.stackMode "replace")}}selected{{/if}}>Substituir</option>
                                <option value="stack" {{#if (eq system.statusBinding.stackMode "stack")}}selected{{/if}}>Empilhar</option>
                            </select>
                        </div>
                        <div class="effect-field effect-field-row">
                            <label class="effect-label">Limite de stacks</label>
                            <input type="number" min="1" step="1" name="system.statusBinding.stackLimit" value="{{system.statusBinding.stackLimit}}"/>
                        </div>
                    </div>
                    <div class="checkbox-options" style="margin-bottom: 10px;">
                        <label class="custom-checkbox">
                            <input type="checkbox" name="system.statusBinding.enabled" {{checked system.statusBinding.enabled}}/>
                            <span>Habilitado para vínculo por status</span>
                        </label>
                        <label class="custom-checkbox">
                            <input type="checkbox" name="system.statusBinding.removeOnStatusOff" {{checked system.statusBinding.removeOnStatusOff}}/>
                            <span>Remover efeitos quando status sair</span>
                        </label>
                    </div>
                    {{else}}
                    <p class="hint">Modo <strong>When</strong> ativo: vínculo de status definido como <strong>sem vínculo</strong>.</p>
                    {{/if}}

                    {{#if (eq system.bindingMode "conditional")}}
                    <div class="condition-input-area">
                        <textarea name="system.when" rows="6" placeholder="ex: actor.system.attributes.hp.value <= 10">{{system.when}}</textarea>
                        <div class="button-group">
                            <a class="button saved-triggers-btn" title="Buscar Gatilho Salvo">
                                <i class="fas fa-bookmark"></i>
                                Gatilhos Salvos
                            </a>
                            <a class="button condition-assistant-btn" title="Assistente de Condições">
                                <i class="fas fa-magic"></i>
                                Assistente de Construção
                            </a>
                        </div>
                    </div>
                    {{else}}
                    <p class="hint">No modo <strong>Vínculo de Status</strong>, o campo <code>when</code> fica oculto para evitar conflitos.</p>
                    {{/if}}
                </section>
            </div>

            {{!-- ABA: EFEITOS --}}
            <div class="tab" data-group="primary" data-tab="effects">

                <section class="modifiers-tab">
                   <div class="eqpmod-block">

                        {{!-- Header padrão + plus minimalista (MESMO DO EQP_MODIFIERS) --}}
                        <div class="eqpmod-block-header">
                            <h4 class="eqpmod-block-title">Efeitos Vinculados</h4>
                            <a class="eqpmod-add-button add-effect" title="Adicionar Efeito">
                                <i class="fas fa-plus"></i>
                            </a>
                        </div>

<div class="effects-line-list">
  {{#if preparedEffects.length}}
    <ol class="effects-list effects-line-list">
      {{#each preparedEffects as |effect|}}
        <li class="effect-entry effects-line-item"
            data-effect-index="{{effect.index}}"
            data-effect-uuid="{{effect.uuid}}">

          {{!-- Mantém effect-header/effect-main/effect-controls (hooks do JS),
               mas usa também o layout effects-line + effects-cell --}}
          <div class="effect-header effects-line effects-line-passive">

            <div class="effect-main effects-cell effects-identity">
              <img src="{{effect.img}}" class="effect-icon effects-icon"/>
              <div class="effect-text effects-text">
                <span class="effect-name effects-name">{{effect.name}}</span>
              </div>
            </div>

            <div class="effect-controls effects-cell effects-actions">
              <span class="effects-controls">
                <a class="view-effect" title="Ver Item Efeito Original">
                  <i class="fas fa-eye"></i>
                </a>
                <a class="delete-effect" title="Remover Link do Efeito">
                  <i class="fas fa-trash"></i>
                </a>
              </span>
            </div>

          </div>
        </li>
      {{/each}}
    </ol>
  {{else}}
    <ol class="effects-list effects-line-list">
      <li class="effects-empty empty-hint">Nenhum efeito vinculado.</li>
    </ol>
  {{/if}}
</div>

                    </div>
                </section>
            </div>

        </section>
    </section>

</form>